FLASK_ENV=
FLASK_DEBUG=

API_KEY=

# Choose one OpenStack auth mode:
#   application_credential - recommended for service/middleware deployments
#   password               - useful for local testing or legacy environments
OS_AUTH_TYPE=application_credential

OS_AUTH_URL=
OS_REGION_NAME=
OS_INTERFACE=
OS_IDENTITY_API_VERSION=

# Application Credential auth
OS_APPLICATION_CREDENTIAL_ID=
OS_APPLICATION_CREDENTIAL_SECRET=

# Password auth
OS_USERNAME=
OS_PASSWORD=
OS_USER_DOMAIN_NAME=
OS_PROJECT_NAME=
OS_PROJECT_DOMAIN_NAME=
