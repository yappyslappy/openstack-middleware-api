FLASK_ENV=production
FLASK_DEBUG=False

API_KEY=

INVENTORY_MAX_AGE_SECONDS=900

MYSQL_HOST=<MYSQL_HOST>
MYSQL_PORT=3306
MYSQL_DATABASE=<MYSQL_DATABASE>
MYSQL_USERNAME=<MYSQL_READONLY_USER>
MYSQL_PASSWORD=
MYSQL_CHARSET=utf8mb4
MYSQL_POOL_SIZE=5
MYSQL_MAX_OVERFLOW=10
MYSQL_POOL_RECYCLE=1800

OPENAPI_ENABLED=true
OPENAPI_DOCS_PATH=/docs
OPENAPI_SPEC_PATH=/openapi.json

TRUST_PROXY_HEADERS=false
PROXY_FIX_X_FOR=1
PROXY_FIX_X_PROTO=1
PROXY_FIX_X_HOST=1
PROXY_FIX_X_PORT=1
PROXY_FIX_X_PREFIX=0

# Retained only for future write operations
# Choose one OpenStack auth mode:
#   application_credential - recommended for service/middleware deployments
#   password               - useful for local testing or legacy environments
OS_AUTH_TYPE=application_credential

OS_AUTH_URL=
OS_REGION_NAME=<REGION_NAME>
OS_INTERFACE=public
OS_IDENTITY_API_VERSION=3

# Application Credential auth
OS_APPLICATION_CREDENTIAL_ID=
OS_APPLICATION_CREDENTIAL_SECRET=

# Password auth
OS_USERNAME=
OS_PASSWORD=
OS_USER_DOMAIN_NAME=
OS_PROJECT_NAME=
OS_PROJECT_DOMAIN_NAME=
