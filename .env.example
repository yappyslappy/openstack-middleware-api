FLASK_ENV=production
FLASK_DEBUG=False

API_KEY=

INVENTORY_MAX_AGE_SECONDS=900

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=openstack_inventory
MYSQL_USERNAME=openstack_api
MYSQL_PASSWORD=
MYSQL_CHARSET=utf8mb4
MYSQL_POOL_SIZE=5
MYSQL_MAX_OVERFLOW=10
MYSQL_POOL_RECYCLE=1800

# Retained only for future write operations
# Choose one OpenStack auth mode:
#   application_credential - recommended for service/middleware deployments
#   password               - useful for local testing or legacy environments
OS_AUTH_TYPE=application_credential

OS_AUTH_URL=
OS_REGION_NAME=RegionOne
OS_INTERFACE=public
OS_IDENTITY_API_VERSION=3

# Application Credential auth
OS_APPLICATION_CREDENTIAL_ID=
OS_APPLICATION_CREDENTIAL_SECRET=

# Password auth
OS_USERNAME=
OS_PASSWORD=
OS_USER_DOMAIN_NAME=
OS_PROJECT_NAME=
OS_PROJECT_DOMAIN_NAME=
